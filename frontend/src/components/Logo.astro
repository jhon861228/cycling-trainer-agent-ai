---

<div class="logo">
    <svg
        width="40"
        height="40"
        viewBox="0 0 40 40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
    >
        <rect width="40" height="40" rx="10" fill="url(#logo_grad)"></rect>
        <path d="M20 8L12 22H28L20 8Z" fill="white" fill-opacity="0.2"></path>
        <path d="M22 14L14 26H26L22 14Z" fill="white"></path>
        <circle
            cx="20"
            cy="20"
            r="15"
            stroke="white"
            stroke-opacity="0.1"
            stroke-width="2"></circle>
        <defs>
            <linearGradient
                id="logo_grad"
                x1="0"
                y1="0"
                x2="40"
                y2="40"
                gradientUnits="userSpaceOnUse"
            >
                <stop stop-color="#cf2e2e"></stop>
                <stop offset="1" stop-color="#ff4d4d"></stop>
            </linearGradient>
        </defs>
    </svg>
    <div class="logo-text">
        <span class="brand">AGENT</span><span class="sub">AI</span>
    </div>
</div>

<style>
    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
    }
    .logo-text {
        font-family: var(--font-main);
        font-weight: 900;
        font-size: 1.25rem;
        letter-spacing: -0.5px;
        display: flex;
        align-items: center;
    }
    .brand {
        color: white;
    }
    .sub {
        color: var(--primary);
        margin-left: 2px;
    }
</style>
