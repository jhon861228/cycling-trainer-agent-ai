---

<div id="historyModal" class="modal-overlay">
    <div
        class="modal-content glass-card animate-scale-in"
        style="max-width: 900px;"
    >
        <header class="modal-header">
            <div>
                <h2 id="historyModalTitle">Plan Histórico</h2>
                <p
                    id="historyModalMeta"
                    style="color: var(--text-muted); font-size: 0.9rem;"
                >
                </p>
            </div>
            <button id="closeHistoryModal" class="close-btn">&times;</button>
        </header>

        <div class="modal-body">
            <div id="historyWorkoutsGrid" class="workouts-grid">
                <!-- Se llenará dinámicamente -->
            </div>
        </div>
    </div>
</div>

<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(10px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1100;
        padding: 20px;
    }
    .modal-overlay.active {
        display: flex;
    }
    .modal-content {
        width: 100%;
        max-width: 1000px;
        max-height: 90vh;
        overflow-y: auto;
        padding: 40px;
        background: var(--bg-card);
        border: 1px solid var(--glass-border);
        border-radius: var(--base-radius);
    }
    .close-btn {
        background: var(--surface-raised);
        border: none;
        color: white;
        font-size: 1.5rem;
        cursor: pointer;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }
    .close-btn:hover {
        background: rgba(255, 255, 255, 0.1);
    }
</style>
